# kolaw — Korean Law Aggregator
# Copy to .env and fill in values. Never commit .env.

# ───── law.go.kr Open API (primary live source) ─────
# OC = your registered project name at open.law.go.kr.
# This is NOT a secret — treat it like a username.
# Register: https://open.law.go.kr/LSO/openApi/guideList.do
LAW_GO_KR_OC=

# ───── legalize-kr corpus (offline statutes + git history) ─────
# git clone https://github.com/9bow/legalize-kr  ~/Thairon/legalize-kr
LEGALIZE_KR_PATH=/data/legalize-kr

# ───── LLM Router (Deep mode only — Fast mode does not call an LLM) ─────
LOCAL_LLM_BASE_URL=http://127.0.0.1:8080/v1
LOCAL_LLM_MODEL=qwen3:32b
# Anthropic fallback for Deep mode. Set to 1 to allow paid-API calls.
ALLOW_ANTHROPIC=0
ANTHROPIC_API_KEY=

# ───── Optional supplementary sources ─────
BEOPMANG_BASE_URL=https://api.beopmang.org/api/v4

# Optional MCP integrations (self-host required for real data)
# LEXGUARD_BASE_URL=http://localhost:9099/mcp
# KOLMCP_BASE_URL=http://localhost:3001
# KOLMCP_OC=                                        # falls back to LAW_GO_KR_OC

# ───── kolaw service ─────
PORT=8100
