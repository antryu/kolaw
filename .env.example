# kolaw — Korean Law Library & Research Infra
# Copy to .env and fill in values. Never commit .env.

# ─── Tier 1: Local LLM (no key needed, default) ───
LOCAL_LLM_BASE_URL=http://127.0.0.1:8080/v1
LOCAL_LLM_MODEL=qwen3:32b

# ─── Tier 2: DeepSeek V4 (OpenAI-compatible, far cheaper than Anthropic) ───
# Get key: https://platform.deepseek.com → API Keys
# Pricing (per 1M tokens):
#   v4-flash: input $0.14 / output $0.28  (cache hit: $0.0028)
#   v4-pro:   input $0.435 / output $0.87 (75% discount until 2026-05-31)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-v4-flash
ALLOW_DEEPSEEK=0          # set to "1" to enable as fallback after local
KOLAW_PREFER_DEEPSEEK=0   # set to "1" to use DeepSeek before local

# ─── Tier 3: Anthropic (last resort, anthropic_approval_gate) ───
ALLOW_ANTHROPIC=0
ANTHROPIC_API_KEY=

# ─── Data sources ───
BEOPMANG_BASE_URL=https://api.beopmang.org/api/v4
LEGALIZE_KR_PATH=/data/legalize-kr

# ─── ChromaDB ───
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# ─── API ───
PORT=8100
