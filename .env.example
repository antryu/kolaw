# kolaw — Korean Law Library & Research Infra
# Copy to .env and fill in values. Never commit .env.

# LLM Router
# Primary: local Qwen3-32B via llama-swap (no key needed)
LOCAL_LLM_BASE_URL=http://127.0.0.1:8080/v1
LOCAL_LLM_MODEL=qwen3:32b

# Anthropic fallback — ONLY with explicit Andrew approval (anthropic_approval_gate)
# ALLOW_ANTHROPIC=0  # must be set to "1" after explicit approval
ANTHROPIC_API_KEY=

# Data sources
BEOPMANG_BASE_URL=https://api.beopmang.org/api/v4
LEGALIZE_KR_PATH=/data/legalize-kr

# ChromaDB
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# API
PORT=8100
